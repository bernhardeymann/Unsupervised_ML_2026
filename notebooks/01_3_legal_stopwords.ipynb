   "source": [
    "## 5. Apply Legal Stopword Filter"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 166,
   "id": "24072f0f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Avg tokens before legal stopword removal: 675\n",
      "Avg tokens after legal stopword removal:  414\n",
      "Additional reduction: 38.6%\n"
     ]
    }
   ],
   "source": [
    "def remove_legal_stopwords(text):\n",
    "    tokens = str(text).split()\n",
    "    return \" \".join(t for t in tokens if t not in LEGAL_STOPWORDS)\n",
    "\n",
    "df[\"text_clean\"] = df[\"text_lemmatized\"].apply(remove_legal_stopwords)\n",
    "\n",
    "# Report reduction\n",
    "before = df[\"text_lemmatized\"].str.split().str.len().mean()\n",
    "after  = df[\"text_clean\"].str.split().str.len().mean()\n",
    "print(f\"Avg tokens before legal stopword removal: {before:.0f}\")\n",
    "print(f\"Avg tokens after legal stopword removal:  {after:.0f}\")\n",
    "print(f\"Additional reduction: {(1 - after/before):.1%}\")"
   ]
  },
